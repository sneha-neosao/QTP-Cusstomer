<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    android:id="@+id/co_product"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context="fragments.ProductDetailFragment">


    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/ll_blank"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:orientation="vertical">


            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:orientation="vertical">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/faintGrey"
                    app:cardBackgroundColor="@color/faintGrey"
                    app:cardElevation="0dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/white"
                        android:orientation="vertical">


                        <RelativeLayout
                            android:id="@+id/image_relative"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="top">

                            <ImageView
                                android:id="@+id/img_product"
                                android:layout_width="match_parent"
                                android:layout_height="170dp"
                                />


                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:id="@+id/right"
                                android:layout_marginRight="10dp"
                                android:layout_marginTop="5dp"
                                android:orientation="vertical"
                                android:layout_alignParentRight="true"
                                android:clickable="true"
                                android:gravity="right">

                                <ImageView
                                    android:id="@+id/imgFavorite"
                                    android:layout_width="25dp"
                                    android:layout_height="25dp"
                                    android:src="@drawable/ic_favorite_24" />

                                <ImageView
                                    android:id="@+id/img_label"
                                    android:layout_width="25dp"
                                    android:layout_height="25dp"
                                    android:layout_marginTop="30dp"
                                    android:src="@drawable/leaf" />

                                <ImageView
                                    android:visibility="gone"
                                    android:id="@+id/img_zoom1"
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_marginTop="50dp"
                                    android:src="@drawable/ic_zoom" />

                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/btn_minus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@android:color/transparent"
                                android:clickable="true"
                                android:orientation="vertical"
                                android:visibility="visible">

                                <ImageView
                                    android:id="@+id/img_qtp_choice"
                                    android:layout_width="50dp"
                                    android:visibility="visible"
                                    android:layout_height="20dp"
                                    android:src="@drawable/img_qtp_choice" />

                            </LinearLayout>

                            <com.smarteist.autoimageslider.SliderView
                                android:id="@+id/slider_view"
                                android:visibility="gone"
                                android:layout_alignParentBottom="true"
                                android:layout_width="match_parent"
                                android:layout_height="170dp"
                                app:sliderAnimationDuration="600"
                                app:sliderAutoCycleDirection="back_and_forth"
                                app:sliderAutoCycleEnabled="false"
                                app:sliderIndicatorAnimationDuration="600"
                                app:sliderIndicatorGravity="center_horizontal|bottom"
                                app:sliderIndicatorMarginTop="8dp"
                                app:sliderIndicatorOrientation="horizontal"
                                app:sliderIndicatorPadding="3dp"
                                app:sliderIndicatorRadius="1dp"
                                app:sliderIndicatorSelectedColor="@color/darkGrey"
                                app:sliderIndicatorUnselectedColor="@color/lightGrey"
                                app:sliderScrollTimeInSec="2"
                                app:sliderStartAutoCycle="false" />


                        </RelativeLayout>

                        <RelativeLayout
                            android:layout_width="wrap_content"
                            android:layout_height="150dp"
                            android:layout_marginTop="30dp"
                            android:layout_marginLeft="10dp"
                            android:gravity="clip_vertical">

                            <androidx.appcompat.widget.AppCompatRatingBar
                                android:id="@+id/ratingBar"
                                style="@style/RatingBar"
                                android:layout_marginTop="30dp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:max="5"
                                android:layout_marginLeft="-20dp"
                                android:rating="0"
                                android:rotation="90"
                                android:progressTint="@color/duskYellow"
                                android:visibility="visible" />


                        </RelativeLayout>

                    </RelativeLayout>

                    <ImageView
                        android:id="@+id/img_zoom"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginRight="10dp"
                        android:layout_marginBottom="10dp"
                        android:layout_gravity="bottom|end"
                        android:src="@drawable/ic_zoom" />

                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:background="@drawable/solid_bg_gray_rounded">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="13dp"
                    android:elevation="8dp"
                    android:layout_margin="15dp"
                    app:cardElevation="8dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/txt_prodName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="18sp"
                            android:textColor="@color/black"
                            android:layout_gravity="center"
                            android:gravity="center"
                            android:text="Product Name"
                            />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_gravity="center"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvCurrency"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textColor="@color/hintColor"
                            android:layout_gravity="center"
                            android:gravity="center"
                            android:text="AED"
                            />
                        <TextView
                            android:id="@+id/txt_new_price"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:layout_marginLeft="5dp"
                            android:textStyle="bold"
                            android:textColor="@color/colorPrimary"
                            android:layout_gravity="center"
                            android:gravity="center"
                            android:text="5.65"
                            />

                        <TextView
                            android:id="@+id/txt_old_price"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:layout_marginLeft="5dp"
                            android:textColor="@color/hintColor"
                            android:layout_gravity="center"
                            android:gravity="center"
                            android:text="5.65"
                            />
                    </LinearLayout>

                        <TextView
                            android:id="@+id/txt_rating_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="4.5(28)"
                            android:layout_gravity="center"
                            android:gravity="center"
                            android:textSize="12sp"
                            android:textColor="@color/hintColor"
                            android:drawableTint="@color/hintColor"
                            android:layout_marginTop="15dp"
                            android:drawableLeft="@drawable/ic_baseline_star_outline_24"
                            />

                   <androidx.recyclerview.widget.RecyclerView
                       android:id="@+id/rv_variant"
                       android:layout_width="match_parent"
                       android:layout_height="wrap_content"
                       android:layout_gravity="center"
                       android:orientation="horizontal"
                       />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_gravity="center"
                        android:gravity="center"
                        android:layout_margin="15dp"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/img_minus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:tint="@color/aqua"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_solid_remove_circle"
                            />

                        <TextView
                            android:id="@+id/tvItemCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:layout_gravity="center"
                            android:gravity="center"
                            android:textSize="16sp"
                            android:layout_marginLeft="10dp"
                            android:layout_marginRight="10dp"
                            android:textColor="@color/black"
                            />

                        <ImageView
                            android:id="@+id/img_add"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:tint="@color/aqua"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_baseline_add_circle_24"
                            />

                    </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="15dp"
                    android:layout_marginRight="15dp"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/ll_download"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:gravity="center"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/download"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Download"
                            android:layout_marginTop="5dp"
                            android:textSize="12sp"
                            android:textColor="@color/black"
                            />

                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/ll_facebook_share"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:gravity="center"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/facebook"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Facebook"
                            android:textSize="12sp"
                            android:layout_marginTop="5dp"
                            android:textColor="@color/black"
                            />

                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/ll_share_others"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:gravity="center"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/share"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Others"
                            android:textSize="12sp"
                            android:layout_marginTop="5dp"
                            android:textColor="@color/black"
                            />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/ll_whatsapp_share"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.9"
                        android:layout_gravity="bottom"
                        android:gravity="bottom"
                        android:background="@drawable/solid_bg_aqua"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="5dp"
                            android:layout_gravity="center"
                            android:gravity="center"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                app:tint="@color/white"
                                android:src="@drawable/mywhatsapp"
                                />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Share Now"
                                android:textSize="8sp"
                                android:layout_marginLeft="5dp"
                                android:textColor="@color/white"
                                />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="13dp"
                    android:elevation="8dp"
                    android:layout_margin="15dp"
                    app:cardElevation="8dp"
                    >


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="10dp"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="18sp"
                            android:layout_weight="1"
                            android:textStyle="bold"
                            android:textColor="@color/black"
                            android:text="Details"
                            />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="16sp"
                            android:textColor="@color/orange"
                            android:text="Copy"
                            android:padding="2dp"
                            android:drawableLeft="@drawable/ic_baseline_content_copy_24"
                            android:drawableTint="@color/orange"
                            android:drawablePadding="5dp"
                            />

                    </LinearLayout>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:cardCornerRadius="13dp"
                            android:elevation="8dp"
                            android:layout_marginTop="15dp"
                            android:backgroundTint="@color/aqua"
                            app:cardElevation="8dp"
                            >

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_margin="12dp"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/txt_desc"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:textColor="@color/white"
                                    android:textSize="12sp"
                                    android:text=""
                                    />

                            </LinearLayout>


                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>

                    <RelativeLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="45dp"
                        android:layout_marginLeft="30dp"
                        >
                        <ImageView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            app:tint="@color/white"
                            android:src="@drawable/ic_baseline_circle_24"/>


                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            app:tint="@color/orange"
                            android:layout_centerInParent="true"
                            android:src="@drawable/ic_baseline_circle_24"/>

                    </RelativeLayout>

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cv_review_count"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="13dp"
                    android:elevation="8dp"
                    android:layout_margin="15dp"
                    app:cardElevation="8dp"
                    >

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="15dp"
                        android:layout_marginRight="15dp"
                        android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:text="Reviews"
                        />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="15dp"
                            android:layout_marginBottom="15dp"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_weight="2"
                                android:orientation="vertical">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal">

                                    <TextView
                                        android:id="@+id/txt_total_rating"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="4.5"
                                        android:textStyle="bold"
                                        android:textSize="28sp"
                                        android:textColor="@color/aqua"
                                        />
                                    <ImageView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        app:tint="@color/aqua"
                                        android:src="@drawable/ic_baseline_star_24"
                                        />

                                </LinearLayout>

                                <TextView
                                    android:id="@+id/txt_rating"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="6 Rating"
                                    android:textSize="12sp"
                                    android:layout_marginTop="5dp"
                                    android:textColor="@color/hintColor"
                                    />

                                <TextView
                                    android:id="@+id/txt_review_count"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="3 Reviews"
                                    android:textSize="12sp"
                                    android:layout_marginTop="5dp"
                                    android:textColor="@color/hintColor"
                                    />

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:gravity="center"
                                    android:orientation="horizontal">

                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_weight="2"
                                        android:layout_height="wrap_content"
                                        android:textColor="@color/black"
                                        android:textSize="14sp"
                                        android:text="Excellent"
                                        />

                                    <ProgressBar
                                        android:id="@+id/pb_excellent"
                                        android:layout_width="match_parent"
                                        android:layout_marginLeft="10dp"
                                        android:layout_weight="1"
                                        android:progress="80"
                                        android:progressTint="@color/aqua"
                                        android:layout_height="25dp"
                                        style="@android:style/Widget.Holo.Light.ProgressBar.Horizontal"
                                        />

                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="5dp"
                                    android:layout_gravity="center"
                                    android:gravity="center"
                                    android:orientation="horizontal">

                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_weight="2"
                                        android:layout_height="wrap_content"
                                        android:textColor="@color/black"
                                        android:textSize="14sp"
                                        android:text="Very Good"
                                        />

                                    <ProgressBar
                                        android:id="@+id/pb_very_good"
                                        android:layout_width="match_parent"
                                        android:layout_height="25dp"
                                        android:layout_marginLeft="10dp"
                                        android:layout_weight="1"
                                        android:progress="70"
                                        android:progressTint="@color/aqua"
                                        style="@android:style/Widget.Holo.Light.ProgressBar.Horizontal"
                                        />

                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="5dp"
                                    android:layout_gravity="center"
                                    android:gravity="center"
                                    android:orientation="horizontal">

                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_weight="2"
                                        android:layout_height="wrap_content"
                                        android:textColor="@color/black"
                                        android:textSize="14sp"
                                        android:text="Good"
                                        />

                                    <ProgressBar
                                        android:id="@+id/pb_good"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginLeft="10dp"
                                        android:layout_weight="1"
                                        android:progress="50"
                                        android:progressTint="@color/duskYellow"
                                        style="@android:style/Widget.Holo.Light.ProgressBar.Horizontal"
                                        />

                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="5dp"
                                    android:layout_gravity="center"
                                    android:gravity="center"
                                    android:orientation="horizontal">

                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_weight="2"
                                        android:layout_height="wrap_content"
                                        android:textColor="@color/black"
                                        android:textSize="14sp"
                                        android:text="Average"
                                        />

                                    <ProgressBar
                                        android:id="@+id/pb_average"
                                        android:layout_width="match_parent"
                                        android:layout_weight="1"
                                        android:layout_height="wrap_content"
                                        android:layout_marginLeft="10dp"
                                        android:progress="30"
                                        android:progressTint="@color/red"
                                        style="@android:style/Widget.Holo.Light.ProgressBar.Horizontal"
                                        />

                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="5dp"
                                    android:layout_gravity="center"
                                    android:gravity="center"
                                    android:orientation="horizontal">

                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:textColor="@color/black"
                                        android:textSize="14sp"
                                        android:layout_weight="2"
                                        android:text="Poor"
                                        />

                                    <ProgressBar
                                        android:id="@+id/pb_poor"
                                        android:layout_width="match_parent"
                                        android:layout_weight="1"
                                        android:layout_height="wrap_content"
                                        android:layout_marginLeft="10dp"
                                        android:progress="10"
                                        android:progressTint="@color/red"
                                        style="@android:style/Widget.Holo.Light.ProgressBar.Horizontal"
                                        />

                                </LinearLayout>

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>


                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cv_review"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="13dp"
                    android:elevation="8dp"
                    android:layout_margin="15dp"
                    app:cardElevation="8dp"
                    >


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="10dp"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textSize="18sp"
                                android:layout_weight="1"
                                android:textStyle="bold"
                                android:textColor="@color/black"
                                android:text="Reviews(28)"
                                />
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/directional_arrows"
                                />

                        </LinearLayout>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:cardCornerRadius="13dp"
                            android:elevation="8dp"
                            android:layout_marginTop="15dp"
                            android:backgroundTint="@color/aqua"
                            app:cardElevation="8dp"
                            >

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_margin="15dp"
                                android:orientation="vertical">

                                <androidx.recyclerview.widget.RecyclerView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:id="@+id/rv_reviews"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="match_parent"
                                    android:layout_gravity="center"
                                    android:gravity="center"
                                    android:textSize="14sp"
                                    android:text="View More"
                                    android:textColor="@color/white"
                                    android:paddingLeft="8dp"
                                    android:paddingRight="8dp"
                                    android:paddingTop="5dp"
                                    android:paddingBottom="5dp"
                                    android:layout_marginTop="10dp"
                                    android:background="@drawable/outlined_square_gray"
                                    />

                            </LinearLayout>


                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>

                    <RelativeLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="45dp"
                        android:layout_marginLeft="30dp"
                        >
                        <ImageView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            app:tint="@color/white"
                            android:src="@drawable/ic_baseline_circle_24"/>


                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            app:tint="@color/orange"
                            android:layout_centerInParent="true"
                            android:src="@drawable/ic_baseline_circle_24"/>

                    </RelativeLayout>

                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:text="Back to top"
                    android:drawableTint="@color/black"
                    android:drawablePadding="5dp"
                    android:drawableRight="@drawable/ic_baseline_arrow_upward_24"
                    android:textColor="@color/black"
                    />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="30dp"
                    android:orientation="horizontal"
                    android:visibility="gone"
                    android:id="@+id/llRecommendations">

                    <RelativeLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="200dp"
                            android:backgroundTint="@color/aqua"
                            android:background="@drawable/solid_bg_half_rounded"
                            android:textSize="16sp"
                            android:gravity="center"
                            android:text="                "
                            android:layout_marginLeft="-20dp"
                            android:layout_centerVertical="true"
                            android:textColor="@color/black"

                            />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="140dp"
                            android:layout_marginBottom="10dp"
                            android:textSize="16sp"
                            android:gravity="center"
                            android:text="*  Recommendations  *"
                            android:rotation="-90"
                            android:layout_centerInParent="true"
                            android:layout_marginLeft="-180dp"
                            android:layout_centerVertical="true"
                            android:textColor="@color/white"
                            android:padding="10dp"

                            />
                    </RelativeLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_recommended"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/white"
                    android:layout_marginTop="20dp"
                    android:orientation="vertical">

                    <androidx.recyclerview.widget.RecyclerView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:id="@+id/rv_recentSearch"
                        android:orientation="horizontal"/>

                </LinearLayout>

            </LinearLayout>



        </LinearLayout>

    </ScrollView>


</androidx.coordinatorlayout.widget.CoordinatorLayout>