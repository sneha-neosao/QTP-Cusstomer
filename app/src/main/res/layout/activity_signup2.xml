<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/back_bg"
    >


    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">


                <androidx.coordinatorlayout.widget.CoordinatorLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/iv_back_login"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/ic_arrow_back_black_24dp"
                        android:layout_marginStart="5dp"
                        android:layout_marginTop="5dp"
                        android:padding="10dp"
                        android:background="?attr/selectableItemBackground"
                        />

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:visibility="gone"
                        android:src="@drawable/qtpbrandkit"/>

                    <ImageView
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:layout_gravity="center"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="10dp"
                        android:src="@drawable/small_logo"/>

                </androidx.coordinatorlayout.widget.CoordinatorLayout>



                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:text="Sign Up"
                    android:textColor="@color/white"
                    app:fontFamily="@font/montserrat_semi_bold"
                    android:textSize="24sp" />


                <TextView
                    android:id="@+id/hi_txt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="Hi,Welcome"
                    android:textColor="@color/white"
                    app:fontFamily="@font/montserrat_medium"
                    android:textSize="24sp"/>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:textColor="#80FFFFFF"
                    android:text="Please Sign up to Continue"
                    app:fontFamily="@font/montserrat_medium"
                    android:textSize="18sp" />

            </LinearLayout>


            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/header">


                <RelativeLayout
                    android:id="@+id/relative_upper"
                    android:layout_width="match_parent"
                    android:layout_height="635dp"
                    android:background="@drawable/registration_bg_top">

                    <LinearLayout
                        android:id="@+id/reg_layout"
                        android:layout_marginTop="20dp"
                        android:layout_marginLeft="42dp"
                        android:layout_marginRight="32dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!--Name-->
                        <LinearLayout
                            android:layout_marginTop="5dp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            >
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                app:fontFamily="@font/montserrat_semi_bold"
                                android:textSize="12sp"
                                android:textColor="#80000000"
                                android:textAllCaps="true"
                                android:text="Name"/>
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <ImageView
                                    android:id="@+id/name_iv"
                                    android:layout_gravity="center_vertical"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:background="@drawable/ic_icon_feather_user"
                                    />

                                <com.google.android.material.textfield.TextInputLayout
                                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                                    android:layout_width="match_parent"
                                    android:layout_weight="1"
                                    android:layout_height="wrap_content"
                                    app:hintTextColor="@color/black"
                                    >


                                    <com.google.android.material.textfield.TextInputEditText
                                        android:id="@+id/edt_name"
                                        android:textColor="@color/black"
                                        android:inputType="textPersonName"
                                        android:paddingBottom="5dp"
                                        android:background="@android:color/transparent"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        />

                                </com.google.android.material.textfield.TextInputLayout>



                            </LinearLayout>

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="@color/mediumGrey"
                                />


                        </LinearLayout>

                        <!--Email-->
                        <LinearLayout
                            android:layout_marginTop="5dp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            >
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                app:fontFamily="@font/montserrat_semi_bold"
                                android:textSize="12sp"
                                android:textColor="#80000000"
                                android:textAllCaps="true"
                                android:text="Email"/>
                            <LinearLayout

                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="horizontal">
                                <ImageView
                                    android:id="@+id/emails_iv"
                                    android:layout_gravity="center"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:background="@drawable/ic_icon_feather_mail_2"
                                    />
                                <com.google.android.material.textfield.TextInputLayout
                                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                                    android:layout_width="match_parent"
                                    android:layout_weight="1"
                                    android:layout_height="wrap_content"
                                    app:hintTextColor="@color/black"
                                    >

                                    <com.google.android.material.textfield.TextInputEditText
                                        android:id="@+id/edt_email"
                                        android:textColor="@color/black"
                                        android:inputType="textEmailAddress"
                                        android:paddingBottom="5dp"
                                        android:background="@android:color/transparent"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content" />

                                </com.google.android.material.textfield.TextInputLayout>


                            </LinearLayout>

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="@color/mediumGrey"
                                />
                        </LinearLayout>

                        <!--Contact-->
                        <LinearLayout
                            android:layout_marginTop="5dp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            >
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                app:fontFamily="@font/montserrat_semi_bold"
                                android:textSize="12sp"
                                android:textColor="#80000000"
                                android:textAllCaps="true"
                                android:text="Contact"/>
                            <LinearLayout
                                android:layout_gravity="center"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:orientation="horizontal">


                                <ImageView
                                    android:id="@+id/contact_iv"
                                    android:layout_gravity="center_vertical"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:background="@drawable/ic_mobile_2"
                                    android:layout_marginEnd="8dp"

                                    />


                                <com.hbb20.CountryCodePicker
                                    android:id="@+id/ccp1"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:visibility="visible"
                                    app:ccp_defaultNameCode="AE"
                                    app:ccp_textSize="12sp" />

                                <com.google.android.material.textfield.TextInputLayout
                                    android:visibility="visible"
                                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:layout_weight="1"
                                    app:hintTextColor="@color/black"
                                    >

                                    <com.google.android.material.textfield.TextInputEditText
                                        android:id="@+id/edt_mobile"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_gravity="center"
                                        android:background="@android:color/transparent"
                                        android:textSize="13sp"
                                        android:paddingBottom="2dp"
                                        android:paddingRight="0dp"
                                        android:textColor="@color/hintColor"
                                        android:maxLength="15"
                                        android:layout_marginStart="5dp"
                                        android:layout_marginBottom="0dp"
                                        android:inputType="number" />

                                </com.google.android.material.textfield.TextInputLayout>

                            </LinearLayout>

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="@color/mediumGrey"
                                />

                        </LinearLayout>

                        <!--Password-->
                        <LinearLayout
                            android:layout_marginTop="5dp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            >
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                app:fontFamily="@font/montserrat_semi_bold"
                                android:textSize="12sp"
                                android:textColor="#80000000"
                                android:textAllCaps="true"
                                android:text="Password"/>
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">
                                <ImageView
                                    android:layout_gravity="center_vertical"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:background="@drawable/ic_icon_feather_lock"
                                    />

                                <com.google.android.material.textfield.TextInputLayout
                                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    app:hintTextColor="@color/black"
                                    app:passwordToggleEnabled="true"
                                    android:layout_weight="1">

                                    <com.google.android.material.textfield.TextInputEditText
                                        android:paddingTop="5dp"
                                        android:id="@+id/edt_pass"
                                        android:background="@android:color/transparent"
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:paddingBottom="5dp"
                                        android:textColor="@color/hintColor"
                                        android:inputType="textPassword" />

                                </com.google.android.material.textfield.TextInputLayout>


                                <ImageView
                                    android:id="@+id/pass_iv"
                                    android:layout_margin="5dp"
                                    android:layout_gravity="center_vertical"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:background="@drawable/ic_icon_feather_eye"
                                    android:visibility="gone"
                                    />

                            </LinearLayout>

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="@color/mediumGrey"
                                />
                        </LinearLayout>

                        <!--Confirm Password-->
                        <LinearLayout
                            android:layout_marginTop="5dp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            >
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                app:fontFamily="@font/montserrat_semi_bold"
                                android:textSize="12sp"
                                android:textColor="#80000000"
                                android:textAllCaps="true"
                                android:text="Confirm Password"/>
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">
                                <ImageView

                                    android:layout_gravity="center_vertical"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:background="@drawable/ic_icon_feather_lock"
                                    />
                                <com.google.android.material.textfield.TextInputLayout
                                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    app:hintTextColor="@color/black"
                                    android:layout_weight="1"
                                    app:passwordToggleEnabled="true"
                                    >

                                    <com.google.android.material.textfield.TextInputEditText
                                        android:id="@+id/edt_con_pass"
                                        android:paddingBottom="5dp"
                                        android:textColor="@color/hintColor"
                                        android:inputType="textPassword"
                                        android:background="@android:color/transparent"
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"/>

                                </com.google.android.material.textfield.TextInputLayout>
                                <ImageView
                                    android:visibility="gone"
                                    android:id="@+id/con_pass_iv"
                                    android:layout_margin="5dp"
                                    android:layout_gravity="center_vertical"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:background="@drawable/ic_icon_feather_eye"
                                    />

                            </LinearLayout>

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="@color/mediumGrey"
                                />


                        </LinearLayout>

                        <!--Referral Code-->
                        <LinearLayout
                            android:layout_marginTop="5dp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            >
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                app:fontFamily="@font/montserrat_semi_bold"
                                android:textSize="12sp"
                                android:textColor="#80000000"
                                android:textAllCaps="true"
                                android:text="Referral Code (Optional)"/>
                            <LinearLayout

                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="horizontal">
                                <ImageView
                                    android:id="@+id/referal_code_iv"
                                    android:layout_gravity="center"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:background="@drawable/ic_refer_earn"
                                    android:backgroundTint="#00000000"
                                    />
                                <com.google.android.material.textfield.TextInputLayout
                                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                                    android:layout_width="match_parent"
                                    android:layout_weight="1"
                                    android:layout_height="wrap_content"
                                    app:hintTextColor="@color/black"
                                    >

                                    <com.google.android.material.textfield.TextInputEditText
                                        android:id="@+id/edt_referal_code"
                                        android:textColor="@color/black"
                                        android:inputType="textCapCharacters"
                                        android:paddingBottom="5dp"
                                        android:background="@android:color/transparent"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content" />

                                </com.google.android.material.textfield.TextInputLayout>


                            </LinearLayout>

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="@color/mediumGrey"
                                />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginTop="5dp">

                                <CheckBox
                                    android:minWidth="0dp"
                                    android:minHeight="0dp"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:buttonTint="#004C3F"
                                    android:layout_marginEnd="5dp"
                                    android:checked="false"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/agree_to_our_terms"
                                    android:textSize="12sp"
                                    android:textColor="@color/colorPrimary"
                                    app:fontFamily="@font/montserrat_semi_bold"/>

                            </LinearLayout>

                            <de.hdodenhof.circleimageview.CircleImageView
                                android:id="@+id/sign_in_img"
                                android:layout_width="50dp"
                                android:layout_height="50dp"
                                android:layout_gravity="right"
                                android:layout_marginTop="40dp"
                                android:src="@drawable/next"
                                />

                        </LinearLayout>
                    </LinearLayout>


                </RelativeLayout>

                <RelativeLayout
                    android:id="@+id/relative_lower"
                    android:layout_width="match_parent"
                    android:layout_height="260dp"
                    android:layout_marginTop="490dp"
                    android:layout_marginRight="3dp"
                    android:background="@drawable/registration_bg_bottom"
                    android:visibility="visible">

                    <LinearLayout
                        android:id="@+id/ll_lower"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerHorizontal="true"
                        android:layout_marginTop="130dp"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="OR"
                            android:textColor="@color/colorPrimary"
                            android:textSize="10sp"
                            app:fontFamily="@font/montserrat_semi_bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Login with social media"
                            android:textColor="@color/colorPrimary"
                            android:textSize="10sp"
                            app:fontFamily="@font/montserrat_semi_bold" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginTop="10dp"
                            android:orientation="horizontal">

                            <de.hdodenhof.circleimageview.CircleImageView
                                android:id="@+id/ivFbSignIn"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:src="@drawable/facebook_logo" />


                            <com.facebook.login.widget.LoginButton
                                android:id="@+id/fb_login_button"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_horizontal"
                                android:layout_marginTop="30dp"
                                android:layout_marginBottom="30dp"
                                android:visibility="gone" />

                            <de.hdodenhof.circleimageview.CircleImageView
                                android:id="@+id/ivGoogleSignIn"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:layout_marginLeft="20dp"
                                android:src="@drawable/google_logo" />

                            <de.hdodenhof.circleimageview.CircleImageView
                                android:layout_width="60dp"
                                android:layout_height="60dp"
                                android:layout_marginLeft="10dp"
                                android:visibility="gone" />


                        </LinearLayout>


                    </LinearLayout>


                </RelativeLayout>


                <LinearLayout
                    android:layout_below="@id/relative_lower"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:layout_marginBottom="10dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/btn_txt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:text="Already have an account ?"
                        android:textColor="@color/white"
                        app:fontFamily="@font/montserrat_medium"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/btn_Signup"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:onClick="onClickNext"
                        app:fontFamily="@font/montserrat_bold"
                        android:text=" Sign In"
                        android:textColor="@color/white"
                        android:textSize="10sp" />
                </LinearLayout>
            </RelativeLayout>


        </LinearLayout>

    </ScrollView>

</RelativeLayout>