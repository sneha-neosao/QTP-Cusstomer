<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:id="@+id/clFavourite"
    android:background="@color/white">



    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:layout_margin="7dp">

        <LinearLayout
            android:id="@+id/llFavourite"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_margin="5dp"
            android:layout_weight="2"
            android:weightSum="2">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:background="@color/white"
                android:orientation="vertical">


                <ImageView
                    android:id="@+id/prodImage"
                    android:layout_width="65dp"
                    android:layout_height="65dp"
                    android:layout_gravity="center"
                    android:layout_marginRight="2dp"
                    android:elevation="0dp"
                    android:src="@drawable/noimageavailable"/>
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="3dp"
                android:layout_marginBottom="3dp"
                android:layout_marginLeft="8dp"
                android:layout_marginRight="3dp"
                android:orientation="vertical">

                <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/txt_pName"
                        android:layout_weight="1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="left"
                        android:fontFamily="@font/montserrat_semibold"
                        android:gravity="center|left"
                        android:text="Product Name"
                        android:textColor="@color/darkGrey"
                        android:textSize="13sp"/>

                    <TextView
                        android:id="@+id/txt_close"
                        android:layout_width="15dp"
                        android:layout_height="15dp"
                        android:layout_marginTop="4dp"
                        android:layout_gravity="left"
                        android:text=""
                        android:textColor="@color/white"
                        android:padding="2dp"
                        android:background="@drawable/ic_baseline_close_24"
                        android:textStyle="bold"
                        android:textSize="10sp"
                        android:elevation="1dp"/>

                </LinearLayout>


                <TextView
                    android:id="@+id/txt_pInfo"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="left"
                    android:layout_marginTop="2dp"
                    android:maxLines="3"
                    android:fontFamily="@font/montserrat_regular"
                    android:gravity="center|left"
                    android:textColor="@color/hintColor"
                    android:textSize="13sp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="7dp"
                    android:layout_marginBottom="3dp"
                    android:layout_weight="2"
                    android:weightSum="2">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">


                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="bottom"
                            >
                            <TextView
                                android:id="@+id/currency_indicator"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="10dp"
                                android:layout_gravity="center"
                                android:fontFamily="@font/montserrat_semibold"
                                android:paddingRight="2dp"
                                android:text="@string/currency"
                                android:textColor="@color/darkGrey"
                                android:textSize="13sp"/>

                            <TextView
                                android:id="@+id/txt_Mrp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="2dp"
                                android:fontFamily="@font/montserrat_regular"
                                android:text="10.2"
                                android:layout_marginRight="1sp"
                                android:textColor="@color/hintColor"
                                android:textSize="10sp"/>

                            <TextView
                                android:id="@+id/txt_Pprice"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/montserrat_semibold"
                                android:text=""
                                android:textColor="@color/darkGrey"
                                android:textSize="15sp"/>

                            <TextView
                                android:id="@+id/txt_Pprice1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/montserrat_semibold"
                                android:text="10"
                                android:textColor="#2E7D32"
                                android:textSize="16sp" />

                            <TextView
                                android:id="@+id/txt_Pprice2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/montserrat_semibold"
                                android:text=".00"
                                android:textColor="@color/darkGrey"
                                android:textSize="10sp" />

                            <TextView
                                android:id="@+id/currency_indicator_2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="10dp"
                                android:layout_gravity="center"
                                android:visibility="gone"
                                android:fontFamily="@font/montserrat_regular"
                                android:gravity="center|left"
                                android:paddingRight="2dp"
                                android:text="@string/currency"
                                android:textColor="@color/hintColor"
                                android:textSize="11sp"/>



                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:id="@+id/quantityLayout"
                        android:gravity="end|center">

                        <LinearLayout
                            android:visibility="visible"
                            android:id="@+id/btn_Add"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:layout_gravity="center"
                                android:paddingLeft="10dp"
                                android:paddingRight="5dp"
                                android:layout_marginLeft="10dp"
                                android:fontFamily="@font/montserrat_semibold"
                                android:gravity="center"
                                android:text="ADD"
                                android:visibility="gone"
                                android:textColor="@color/white"
                                android:textSize="15sp"/>

                            <ImageView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:scaleType="center"
                                android:src="@drawable/ic_add"
                                android:layout_gravity="center"
                                />

                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/ll_addQuan"
                            android:visibility="gone"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:gravity="center"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/minus"
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:layout_gravity="center"
                                android:paddingRight="3dp"
                                android:drawableTint="@color/lightGrey"
                                android:layout_marginLeft="6dp"
                                android:drawableRight="@drawable/ic_outline_remove_circle_outline_24"></TextView>


                            <TextView
                                android:id="@+id/txtQuan"
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:layout_gravity="center"
                                android:paddingRight="2dp"
                                android:paddingLeft="2dp"
                                android:fontFamily="@font/montserrat_semibold"
                                android:gravity="center"
                                android:text="1"
                                android:textColorHint="@color/hintColor"
                                android:textColor="@color/darkGrey"
                                android:textSize="15sp"></TextView>

                            <TextView
                                android:id="@+id/plus"
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:layout_gravity="center"
                                android:paddingLeft="3dp"
                                android:drawableRight="@drawable/ic_add"></TextView>
                        </LinearLayout>

                    </LinearLayout>


                </LinearLayout>



            </LinearLayout>

        </LinearLayout>


        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="@color/lightGrey"/>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/llOutOfStock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:layout_gravity="center"
        android:visibility="gone"
        android:orientation="vertical">
    <TextView
        android:id="@id/tvOutOfStock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:visibility="visible"
        android:text="Out of stock"
        android:textColor="@color/colorPrimary"
        android:textSize="14sp"
        app:fontFamily="@font/montserrat_medium" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:visibility="visible"
            android:text="Show alternatives"
            android:textColor="@color/aqua"
            android:textSize="14sp"
            app:fontFamily="@font/montserrat_semi_bold" />

    </LinearLayout>
    <TextView
        android:id="@+id/txt_close1"
        android:layout_width="15dp"
        android:layout_height="15dp"
        android:layout_marginTop="15dp"
        android:layout_marginEnd="15dp"
        android:layout_gravity="end"
        android:text=""
        android:textColor="@color/white"
        android:padding="2dp"
        android:background="@drawable/ic_baseline_close_24"
        android:textStyle="bold"
        android:textSize="10sp"
        android:visibility="gone"
        android:elevation="1dp"/>



</androidx.coordinatorlayout.widget.CoordinatorLayout>

