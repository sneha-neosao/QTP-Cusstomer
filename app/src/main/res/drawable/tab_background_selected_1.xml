<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item
        android:left="5dp"
        android:right="5dp"
        android:top="5dp"
        android:bottom="5dp">

        <shape
            android:shape="rectangle">

            <corners
                android:radius="30dp">
            </corners>

            <solid android:color="@color/colorPrimary"/>
            <stroke
                android:width="5dp"
                android:color="@color/colorPrimary">
            </stroke>

        </shape>

    </item>

</layer-list>