<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.MaterialComponents.Light.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="fontFamily">@font/montserrat_regular</item>
        <item name="android:windowLightStatusBar" tools:ignore="NewApi">true</item>
        <item name="android:windowDisablePreview">true</item>
    </style>

    <style name="StatusBarGreen" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimaryDark">@color/green</item>
        <item name="fontFamily">@font/montserrat_regular</item>
    </style>

    <style name="boldFont" parent="AppTheme">
        <item name="fontFamily">@font/montserrat_bold</item>
    </style>

    <style name="semiboldFont" parent="AppTheme">
        <item name="fontFamily">@font/montserrat_semibold</item>
    </style>

    <style name="StatusBarWhite" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimaryDark">@color/white</item>
        <item name="fontFamily">@font/montserrat_regular</item>
        <item name="android:windowFullscreen">true</item>
    </style>
    <style name="StatusBarOrange" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="fontFamily">@font/montserrat_regular</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
    </style>

    <style name="CropImageTheme" parent="Theme.AppCompat.DayNight.DarkActionBar">
        <item name="fontFamily">@font/montserrat_regular</item>
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <style name="AppCompatTheme" parent="@style/Theme.AppCompat.Light">
        <item name="android:windowActionBar">false</item>
        <item name="fontFamily">@font/montserrat_regular</item>
    </style>

    <style name="AppTheme.NoActionBar">
        <item name="fontFamily">@font/montserrat_regular</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>
    <style name="RobotoBoldTextAppearance">
        <item name="fontFamily">@font/montserrat_regular</item>
        <item name="android:textColor">#fff</item>
        <item name="android:textSize">@dimen/text_size_large</item>
    </style>

    <style name="MineCustomTabText" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">10sp</item>
        <item name="fontFamily">@font/montserrat_semi_bold</item>
    </style>

    <style name="ProductCustomTabText" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">10sp</item>
        <item name="fontFamily">@font/montserrat_semi_bold</item>
    </style>

    <style name="button_color" parent="AppTheme">
        <item name="backgroundTint">@color/colorPrimary</item>
    </style>

    <style name="AppTheme.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="AppTheme.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />
    <!-- <style name="NavDrawerTextStyle" parent="Base.TextAppearance.AppCompat">
        <item name="android:textColor">#fff</item>
        <item name="android:layout_marginRight">16dp</item>
        <item name="android:layout_marginTop">18dp</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:textSize">15sp</item>
    </style>-->
    
    <style name="NavigationTheme" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="fontFamily">@font/montserrat_regular</item>
        <item name="android:textColorSecondary">@color/colorPrimaryDark</item>
    </style>

    <style name="TextAppearance">
    </style>
    <style name="TextAppearance.BottomNavigationView">
    </style>
    <style name="TextAppearance.BottomNavigationView.Active">
        <item name="fontFamily">@font/montserrat_regular</item>
        <item name="android:textSize">@dimen/bottom_navigation_active_text_size</item>
    </style>
    <style name="TextAppearance.BottomNavigationView.Inactive">
        <item name="fontFamily">@font/montserrat_regular</item>
        <item name="android:textSize">@dimen/bottom_navigation_text_size</item>
    </style>

    <style name="BottomNavigationView">
        <item name="fontFamily">@font/montserrat_regular</item>
        <item name="itemTextAppearanceActive">@style/TextAppearance.BottomNavigationView.Active</item>
        <item name="itemTextAppearanceInactive">@style/TextAppearance.BottomNavigationView.Inactive</item>
    </style>

    <style name="MyCustomTextAppearance" parent="android:Widget.TextView">
        <item name="fontFamily">@font/montserrat_semi_bold</item>
        <item name="textAllCaps">true</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="price_details_txt" parent="Widget.AppCompat.TextView">
        <item name="fontFamily">@font/montserrat_semi_bold</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:paddingEnd" tools:ignore="NewApi">10sp</item>
        <item name="android:gravity">center_vertical</item>
    </style>

    <style name="RatingBar" parent="Widget.AppCompat.RatingBar.Small">
        <item name="colorControlNormal">@color/duskYellow</item>
        <item name="android:layout_gravity">clip_vertical</item>
        <item name="colorControlActivated">@color/lightGrey</item>
    </style>

    <style name="SheetDialog" parent="Theme.Design.Light.BottomSheetDialog">
        <!--<item name="android:windowCloseOnTouchOutside">false</item>-->
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:colorBackground"> @android:color/transparent</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.3</item>
        <item name="android:windowFrame">@null</item>
        <item name="android:windowIsFloating">true</item>
    </style>

    <style name="DialogAnimation">
        <item name="android:windowEnterAnimation">@anim/slide_up_dialog</item>
        <item name="android:windowExitAnimation">@anim/slide_out_down</item>
    </style>


</resources>
